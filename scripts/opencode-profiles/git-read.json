{
  "bash": {
    "git *": "deny",
    "git status": "allow",
    "git status *": "allow",
    "git diff": "allow",
    "git diff *": "allow",
    "git log": "allow",
    "git log *": "allow",
    "git show": "allow",
    "git show *": "allow",
    "git branch": "allow",
    "git branch *": "allow",
    "git fetch": "allow",
    "git fetch *": "allow"
  }
}

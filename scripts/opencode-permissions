#!/usr/bin/env python3
import sqlite3
import os
import json
import sys

def load_profile_recursive(profile_name, profiles_dir, loaded_profiles=None):
    if loaded_profiles is None:
        loaded_profiles = set()
        
    if profile_name in loaded_profiles:
        return {} # Prevent infinite recursion loops
        
    loaded_profiles.add(profile_name)
    
    profile_path = os.path.join(profiles_dir, f"{profile_name}.json")
    if not os.path.exists(profile_path):
        print(f"⚠️  Warning: Inherited permission group '{profile_name}' not found at {profile_path}")
        return {}

    with open(profile_path, 'r') as f:
        try:
            data = json.load(f)
        except json.JSONDecodeError as e:
            print(f"⚠️  Error: Invalid JSON in permission group '{profile_name}': {e}")
            return {}

    # Handle inheritance first
    merged_data = {}
    if "inherit" in data:
        inherits = data["inherit"]
        if isinstance(inherits, str):
            inherits = [inherits]
            
        for parent in inherits:
            parent_data = load_profile_recursive(parent, profiles_dir, loaded_profiles)
            
            # Merge parent data into current data
            for perm_type, rules in parent_data.items():
                if perm_type not in merged_data:
                    merged_data[perm_type] = {}
                
                if isinstance(rules, str):
                    merged_data[perm_type] = rules
                elif isinstance(rules, dict):
                    if not isinstance(merged_data[perm_type], dict):
                        merged_data[perm_type] = {}
                    # Add parent rules
                    for pattern, action in rules.items():
                        if pattern in merged_data[perm_type]:
                            del merged_data[perm_type][pattern]
                        merged_data[perm_type][pattern] = action
                        
    # Now apply the current profile's own rules (they override inherited ones)
    for perm_type, rules in data.items():
        if perm_type == "inherit":
            continue
            
        if perm_type not in merged_data:
            merged_data[perm_type] = {}
            
        if isinstance(rules, str):
            merged_data[perm_type] = rules
        elif isinstance(rules, dict):
            if not isinstance(merged_data[perm_type], dict):
                merged_data[perm_type] = {}
            # Add current rules
            for pattern, action in rules.items():
                if pattern in merged_data[perm_type]:
                    del merged_data[perm_type][pattern]
                merged_data[perm_type][pattern] = action
                
    return merged_data

def get_active_profiles(db_path, profiles_dir):
    if not os.path.exists(db_path): return []
    try:
        conn = sqlite3.connect(db_path)
        cur = conn.cursor()
        cur.execute("SELECT permission FROM session ORDER BY time_updated DESC LIMIT 1")
        row = cur.fetchone()
        conn.close()
        if not row or not row[0]: return []
        current_rules = json.loads(row[0])
    except:
        return []

    active = []
    if not os.path.exists(profiles_dir): return active
    for filename in sorted(os.listdir(profiles_dir)):
        if not filename.endswith('.json'): continue
        profile_name = filename[:-5]
        with open(os.path.join(profiles_dir, filename), 'r') as f:
            try: profile_data = json.load(f)
            except: continue
        
        expected_rules = []
        for perm, val in profile_data.items():
            if perm == 'inherit': continue
            if isinstance(val, str): expected_rules.append({"permission": perm, "pattern": "*", "action": val})
            elif isinstance(val, dict):
                for pat, act in val.items(): expected_rules.append({"permission": perm, "pattern": pat, "action": act})
                
        is_fulfilled = True
        for expected in expected_rules:
            exists = any(r.get('permission') == expected['permission'] and r.get('pattern') == expected['pattern'] and r.get('action') == expected['action'] for r in current_rules)
            if not exists:
                is_fulfilled = False
                break
                
        if is_fulfilled and expected_rules:
            active.append(profile_name)
    return active

def interactive_prompt(profiles, active_profiles):
    import termios
    import tty
    import select

    if not sys.stdin.isatty():
        return None

    options = ["clear"] + profiles
    selected = set()
    for i, opt in enumerate(options):
        if opt in active_profiles:
            selected.add(i)

    cursor = 0

    sys.stdout.write("\n📝 Select Opencode Permission Groups (SPACE to toggle, ENTER to confirm, ESC/q to cancel):\n")
    for _ in options:
        sys.stdout.write("\n")

    def draw():
        sys.stdout.write(f"\x1b[{len(options)}A")
        for i, opt in enumerate(options):
            marker = "❯" if i == cursor else " "
            box = "◉" if i in selected else "◯"
            if opt == "clear":
                color = "\x1b[31m" if i == cursor else "\x1b[0m"
            else:
                color = "\x1b[36m" if i == cursor else "\x1b[0m"
            
            # Dim unselected items
            if i not in selected and i != cursor:
                color += "\x1b[2m"

            line = f"{color}{marker} {box} {opt}\x1b[0m\n"
            sys.stdout.write("\x1b[2K" + line)
        sys.stdout.flush()

    fd = sys.stdin.fileno()
    old_settings = termios.tcgetattr(fd)

    try:
        tty.setraw(fd)
        while True:
            draw()
            ch = sys.stdin.read(1)
            if ch == '\x03' or ch == 'q':
                sys.stdout.write("\nCanceled.\n")
                return None
            elif ch == '\r' or ch == '\n':
                break
            elif ch == ' ':
                if cursor in selected:
                    selected.remove(cursor)
                else:
                    if cursor == 0:
                        selected = {0}
                    else:
                        selected.discard(0)
                        selected.add(cursor)
            elif ch == '\x1b':
                r, _, _ = select.select([sys.stdin], [], [], 0.1)
                if r:
                    ch2 = sys.stdin.read(1)
                    if ch2 == '[':
                        ch3 = sys.stdin.read(1)
                        if ch3 == 'A':
                            cursor = max(0, cursor - 1)
                        elif ch3 == 'B':
                            cursor = min(len(options) - 1, cursor + 1)
                else:
                    sys.stdout.write("\nCanceled.\n")
                    return None
            elif ch == 'k':
                cursor = max(0, cursor - 1)
            elif ch == 'j':
                cursor = min(len(options) - 1, cursor + 1)
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)

    sys.stdout.write("\n")
    return [options[i] for i in sorted(list(selected))]

def apply_profiles(profile_names, db_path, profiles_dir):
    conn = sqlite3.connect(db_path)
    cur = conn.cursor()

    cur.execute("SELECT id FROM session ORDER BY time_updated DESC LIMIT 1")
    row = cur.fetchone()
    if not row:
        print("No sessions found.")
        return
    session_id = row[0]

    if "clear" in [p.lower() for p in profile_names]:
        cur.execute("UPDATE session SET permission = NULL WHERE id = ?", (session_id,))
        conn.commit()
        conn.close()
        print(f"✅ Cleared all temporary permissions for session {session_id}")
        print("   (It will now fallback to your default opencode.json rules)")
        print("\n⚡ The new permissions will take effect on your next chat message!")
        return

    combined_profile_data = {}

    for profile_name in profile_names:
        profile_path = os.path.join(profiles_dir, f"{profile_name}.json")
        if not os.path.exists(profile_path):
            print(f"Error: Permission group file not found at {profile_path}")
            return

        profile_data = load_profile_recursive(profile_name, profiles_dir)

        for perm_type, rules in profile_data.items():
            if perm_type not in combined_profile_data:
                combined_profile_data[perm_type] = {}
                
            if isinstance(rules, str):
                combined_profile_data[perm_type] = rules
            elif isinstance(rules, dict):
                if not isinstance(combined_profile_data[perm_type], dict):
                    combined_profile_data[perm_type] = {}
                for pattern, action in rules.items():
                    if pattern in combined_profile_data[perm_type]:
                        del combined_profile_data[perm_type][pattern]
                    combined_profile_data[perm_type][pattern] = action

    specific_rules = []
    
    for permission, value in combined_profile_data.items():
        if isinstance(value, str):
            specific_rules.append({"permission": permission, "pattern": "*", "action": value})
        elif isinstance(value, dict):
            for pattern, action in value.items():
                specific_rules.append({"permission": permission, "pattern": pattern, "action": action})

    def sort_key(rule):
        # Primary: sort by pattern length (longer = more specific)
        length = len(rule['pattern'])
        
        # Secondary: action priority (allow = 1, deny = 0)
        # We negate action_score so allow comes AFTER deny (higher value = lower in array)
        action_score = 0 if rule['action'] == 'deny' else 1
        
        # We sort ascending, so shorter lengths come first. 
        # For equal lengths, 'deny' (0) comes before 'allow' (1)
        return (length, action_score)
        
    specific_rules.sort(key=sort_key)

    ruleset = [{"permission": "*", "pattern": "*", "action": "allow"}]
    ruleset.extend(specific_rules)

    new_json = json.dumps(ruleset)

    cur.execute("UPDATE session SET permission = ? WHERE time_updated > (strftime('%s', 'now') - 86400) * 1000", (new_json,))
    conn.commit()
    conn.close()

    import datetime
    log_dir = os.path.expanduser("~/.local/state")
    if not os.path.exists(log_dir):
        os.makedirs(log_dir)
    log_file = os.path.join(log_dir, "opencode-permissions.log")
    timestamp = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    joined_profiles = " + ".join(profile_names)
    with open(log_file, "a") as f:
        f.write(f"[{timestamp}] Switched to permission groups: {joined_profiles}\n")

    print(f"✅ Applied combined permission groups '{joined_profiles}' to all recent sessions!")
    print("   Rules applied (bottom-most rules have highest priority!):")
    for rule in ruleset:
        print(f"   - {rule['action'].upper()}: {rule['permission']} -> {rule['pattern']}")
    print("\n⚡ The new permissions will take effect on your next chat message!")

def main():
    db_path = os.path.expanduser("~/.local/share/opencode/opencode.db")
    profiles_dir = os.path.expanduser("~/.config/nvim/scripts/opencode-permission-groups/")

    if len(sys.argv) < 2:
        available_profiles = []
        if os.path.exists(profiles_dir):
            for f in os.listdir(profiles_dir):
                if f.endswith('.json'):
                    available_profiles.append(f[:-5])
        available_profiles.sort()
        
        active_profiles = get_active_profiles(db_path, profiles_dir)
        
        selected = interactive_prompt(available_profiles, active_profiles)
        if selected is None:
            return
        if not selected:
            print("No permission groups selected.")
            return
        profile_names = selected
    else:
        profile_names = sys.argv[1:]

    apply_profiles(profile_names, db_path, profiles_dir)

if __name__ == "__main__":
    main()

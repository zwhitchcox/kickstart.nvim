#!/usr/bin/env node
import fs from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';
import enquirer from 'enquirer';
import Database from 'better-sqlite3';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const PROFILES_DIR = path.join(process.env.HOME, '.config', 'nvim', 'scripts', 'opencode-permission-groups');
const DB_PATH = path.join(process.env.HOME, '.local', 'share', 'opencode', 'opencode.db');
const LOG_PATH = path.join(process.env.HOME, '.local', 'state', 'opencode-permissions.log');

// Function to recursively load and merge profiles
function loadProfileRecursive(profileName, loadedProfiles = new Set()) {
  if (loadedProfiles.has(profileName)) {
    return {}; // Prevent infinite recursion
  }
  loadedProfiles.add(profileName);

  const profilePath = path.join(PROFILES_DIR, `${profileName}.json`);
  if (!fs.existsSync(profilePath)) {
    console.warn(`⚠️  Warning: Inherited permission group '${profileName}' not found at ${profilePath}`);
    return {};
  }

  let data;
  try {
    data = JSON.parse(fs.readFileSync(profilePath, 'utf8'));
  } catch (e) {
    console.warn(`⚠️  Error: Invalid JSON in group '${profileName}': ${e.message}`);
    return {};
  }

  const mergedData = {};

  // Handle inheritance first
  if (data.inherit) {
    const inherits = Array.isArray(data.inherit) ? data.inherit : [data.inherit];
    
    for (const parent of inherits) {
      const parentData = loadProfileRecursive(parent, loadedProfiles);
      
      // Merge parent data into current data
      for (const [permType, rules] of Object.entries(parentData)) {
        if (!mergedData[permType]) {
          mergedData[permType] = {};
        }
        
        if (typeof rules === 'string') {
          mergedData[permType] = rules;
        } else if (typeof rules === 'object') {
          if (typeof mergedData[permType] !== 'object') {
            mergedData[permType] = {};
          }
          // Add parent rules
          for (const [pattern, action] of Object.entries(rules)) {
            mergedData[permType][pattern] = action;
          }
        }
      }
    }
  }

  // Now apply the current profile's own rules (they override inherited ones)
  for (const [permType, rules] of Object.entries(data)) {
    if (permType === 'inherit') continue;
    
    if (!mergedData[permType]) {
      mergedData[permType] = {};
    }
    
    if (typeof rules === 'string') {
      mergedData[permType] = rules;
    } else if (typeof rules === 'object') {
      if (typeof mergedData[permType] !== 'object') {
        mergedData[permType] = {};
      }
      for (const [pattern, action] of Object.entries(rules)) {
        mergedData[permType][pattern] = action;
      }
    }
  }

  return mergedData;
}

// Function to get currently active profiles from the database
function getActiveProfiles() {
  if (!fs.existsSync(DB_PATH)) return [];

  try {
    const db = new Database(DB_PATH, { fileMustExist: true });
    const row = db.prepare("SELECT permission FROM session ORDER BY time_updated DESC LIMIT 1").get();
    db.close();

    if (!row || !row.permission) return [];

    let currentRules = [];
    try {
      currentRules = JSON.parse(row.permission);
    } catch (e) {
      return [];
    }

    if (!fs.existsSync(PROFILES_DIR)) return [];

    const active = [];
    const files = fs.readdirSync(PROFILES_DIR);

    for (const file of files) {
      if (!file.endsWith('.json')) continue;
      
      const profileName = file.replace('.json', '');
      let profileData;
      try {
        profileData = JSON.parse(fs.readFileSync(path.join(PROFILES_DIR, file), 'utf8'));
      } catch (e) {
        continue;
      }

      const expectedRules = [];
      for (const [perm, val] of Object.entries(profileData)) {
        if (perm === 'inherit') continue;
        if (typeof val === 'string') {
          expectedRules.push({ permission: perm, pattern: "*", action: val });
        } else if (typeof val === 'object') {
          for (const [pat, act] of Object.entries(val)) {
            expectedRules.push({ permission: perm, pattern: pat, action: act });
          }
        }
      }

      let isFulfilled = true;
      for (const expected of expectedRules) {
        const exists = currentRules.some(r => 
          r.permission === expected.permission && 
          r.pattern === expected.pattern && 
          r.action === expected.action
        );
        if (!exists) {
          isFulfilled = false;
          break;
        }
      }

      if (isFulfilled && expectedRules.length > 0) {
        active.push(profileName);
      }
    }
    
    return active;
  } catch (e) {
    return [];
  }
}

// Function to apply profiles to the database
function applyProfiles(profileNames) {
  if (!fs.existsSync(DB_PATH)) {
    console.error("Error: Database not found at", DB_PATH);
    process.exit(1);
  }

  const db = new Database(DB_PATH);
  
  // Get latest session ID just for logging if needed
  const row = db.prepare("SELECT id FROM session ORDER BY time_updated DESC LIMIT 1").get();
  if (!row) {
    console.error("No sessions found.");
    process.exit(1);
  }
  const sessionId = row.id;

  // Clear case
  if (profileNames.map(p => p.toLowerCase()).includes('clear')) {
    db.prepare("UPDATE session SET permission = NULL WHERE id = ?").run(sessionId);
    db.close();
    console.log(`✅ Cleared all temporary permissions for session ${sessionId}`);
    console.log("   (It will now fallback to your default opencode.json rules)");
    console.log("\n⚡ The new permissions will take effect on your next chat message!");
    return;
  }

  const combinedProfileData = {};

  for (const profileName of profileNames) {
    const profileData = loadProfileRecursive(profileName);

    // Merge this profile's data into the combined data
    for (const [permType, rules] of Object.entries(profileData)) {
      if (!combinedProfileData[permType]) {
        combinedProfileData[permType] = {};
      }
      
      if (typeof rules === 'string') {
        combinedProfileData[permType] = rules;
      } else if (typeof rules === 'object') {
        if (typeof combinedProfileData[permType] !== 'object') {
          combinedProfileData[permType] = {};
        }
        for (const [pattern, action] of Object.entries(rules)) {
          combinedProfileData[permType][pattern] = action;
        }
      }
    }
  }

  // Build the final ruleset array
  let specificRules = [];

  for (const [permission, value] of Object.entries(combinedProfileData)) {
    if (typeof value === 'string') {
      specificRules.push({ permission, pattern: "*", action: value });
    } else if (typeof value === 'object') {
      for (const [pattern, action] of Object.entries(value)) {
        specificRules.push({ permission, pattern, action });
      }
    }
  }

  // Sort by specificity to ensure specific rules override generic rules,
  // and allows override denys of the exact same length!
  specificRules.sort((a, b) => {
    // 1. Shorter patterns (more generic) go to the top (lower index)
    if (a.pattern.length !== b.pattern.length) {
      return a.pattern.length - b.pattern.length;
    }
    // 2. If lengths are equal, push 'deny' above 'allow' so 'allow' comes last
    if (a.action === 'deny' && b.action !== 'deny') return -1;
    if (a.action !== 'deny' && b.action === 'deny') return 1;
    return 0;
  });

  // ALWAYS inject baseline fallback at the very top
  const ruleset = [
    {
      permission: "*",
      pattern: "*",
      action: "allow"
    },
    ...specificRules
  ];

  const newJson = JSON.stringify(ruleset);

  // Update ALL recent sessions (within 24 hours) to avoid ghost session races
  const oneDayAgo = (Date.now() - 86400000);
  db.prepare("UPDATE session SET permission = ? WHERE time_updated > ?").run(newJson, oneDayAgo);
  db.close();

  // Log the switch
  const timestamp = new Date().toISOString().replace('T', ' ').substring(0, 19);
  const joinedProfiles = profileNames.join(' + ');
  const logDir = path.dirname(LOG_PATH);
  
  if (!fs.existsSync(logDir)) {
    fs.mkdirSync(logDir, { recursive: true });
  }
  fs.appendFileSync(LOG_PATH, `[${timestamp}] Switched to permission groups: ${joinedProfiles}\n`);

  console.log(`✅ Applied combined permission groups '${joinedProfiles}' to all recent sessions!`);
  console.log("   Rules applied (bottom-most rules have highest priority!):");
  for (const rule of ruleset) {
    console.log(`   - ${rule.action.toUpperCase()}: ${rule.permission} -> ${rule.pattern}`);
  }
  console.log("\n⚡ The new permissions will take effect on your next chat message!");
}

async function main() {
  const userArgs = process.argv.slice(2);
  
  if (userArgs.length > 0) {
    applyProfiles(userArgs);
    process.exit(0);
  }

  if (!fs.existsSync(PROFILES_DIR)) {
    console.error(`Error: Permission groups directory not found at ${PROFILES_DIR}`);
    process.exit(1);
  }

  const files = fs.readdirSync(PROFILES_DIR);
  const profiles = files
    .filter(f => f.endsWith('.json'))
    .map(f => f.replace('.json', ''))
    .sort();

  const choices = [
    { name: 'clear', message: 'clear (Reset to default opencode.json rules)' },
    { role: 'separator' },
    ...profiles.map(p => ({ name: p, message: p }))
  ];

  const initialSelections = getActiveProfiles();

  // Prevent Node 20+ readline ERR_USE_AFTER_CLOSE bug
  process.on('SIGINT', () => {
    process.exit(0);
  });

  try {
    const prompt = new enquirer.AutoComplete({
      name: 'selected',
      message: 'Select Opencode permission groups to apply (Space to toggle, Enter to confirm)',
      multiple: true,
      initial: initialSelections,
      choices: choices,
      indicator(state, choice) {
        return choice.enabled ? '◉' : '◯';
      }
    });

    prompt.on('cancel', () => process.exit(0));

    const selected = await prompt.run();

    if (!selected || selected.length === 0) {
      console.log('No permission groups selected. Exiting.');
      process.exit(0);
    }

    console.log(`\nApplying: ${selected.join(' ')}...`);
    applyProfiles(selected);

  } catch (err) {
    // Usually caught by prompt.on('cancel'), but just in case
    process.exit(0);
  }
}

main();

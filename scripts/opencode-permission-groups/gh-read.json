{
  "bash": {
    "gh pr view": "allow",
    "gh pr view *": "allow",
    "gh pr list": "allow",
    "gh pr list *": "allow",
    "gh issue view": "allow",
    "gh issue view *": "allow",
    "gh issue list": "allow",
    "gh issue list *": "allow",
    "gh api repos/*/pulls/*/comments": "allow",
    "gh api repos/*/issues/*/comments": "allow",
    "gh *": "deny"
  }
}

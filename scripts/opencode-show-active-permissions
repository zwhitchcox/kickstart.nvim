#!/usr/bin/env python3
import sqlite3
import os
import json
import sys

def main():
    db_path = os.path.expanduser("~/.local/share/opencode/opencode.db")
    if not os.path.exists(db_path):
        print("Error: Database not found.")
        return

    conn = sqlite3.connect(db_path)
    cur = conn.cursor()

    # Get the most recently active session
    cur.execute("SELECT id, permission FROM session ORDER BY time_updated DESC LIMIT 1")
    row = cur.fetchone()
    if not row:
        print("No sessions found.")
        return
    
    session_id = row[0]
    session_permissions_json = row[1]
    
    current_rules = []
    if session_permissions_json:
        try:
            current_rules = json.loads(session_permissions_json)
        except json.JSONDecodeError:
            pass

    print(f"\n🔐 Current Session Permissions ({session_id})")
    print("=" * 50)
    
    if not current_rules:
        print("No active session overrides. Using global opencode.json defaults.")
    else:
        for rule in current_rules:
            action = f"[{rule.get('action', 'ask').upper()}]"
            print(f"{action:<8} {rule.get('permission', 'any')} -> {rule.get('pattern', '*')}")

    print("\n📦 Active Profiles Analysis")
    print("=" * 50)

    profiles_dir = os.path.expanduser("~/.config/nvim/scripts/opencode-profiles/")
    if not os.path.exists(profiles_dir):
        print("No profiles directory found.")
        return

    # Check which profiles match the current session state
    matched_any = False
    
    for filename in sorted(os.listdir(profiles_dir)):
        if not filename.endswith('.json'):
            continue
            
        profile_name = filename[:-5]
        with open(os.path.join(profiles_dir, filename), 'r') as f:
            try:
                profile_data = json.load(f)
            except:
                continue

        # Convert profile to expected rule format for comparison
        expected_rules = []
        for permission, value in profile_data.items():
            if isinstance(value, str):
                expected_rules.append({"permission": permission, "pattern": "*", "action": value})
            elif isinstance(value, dict):
                for pattern, action in value.items():
                    expected_rules.append({"permission": permission, "pattern": pattern, "action": action})

        # Check if ALL rules from the profile exist exactly in the current session
        is_fulfilled = True
        for expected in expected_rules:
            rule_exists = any(
                r.get('permission') == expected['permission'] and 
                r.get('pattern') == expected['pattern'] and 
                r.get('action') == expected['action'] 
                for r in current_rules
            )
            if not rule_exists:
                is_fulfilled = False
                break

        # Also need to check if the session is empty but the profile requires rules
        if expected_rules and not current_rules:
            is_fulfilled = False
            
        if is_fulfilled and expected_rules:
            print(f"⭐ {profile_name}")
            matched_any = True
        else:
            print(f"   {profile_name}")

    # Show recent switch log
    log_file = os.path.expanduser("~/.local/state/opencode-profile.log")
    if os.path.exists(log_file):
        print("\n📜 Recent Profile Switches")
        print("=" * 50)
        with open(log_file, 'r') as f:
            lines = f.readlines()
            for line in lines[-5:]:  # Show last 5
                print(line.strip())

    print()

if __name__ == "__main__":
    main()

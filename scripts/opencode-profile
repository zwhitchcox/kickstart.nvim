#!/usr/bin/env python3
import sqlite3
import os
import json
import sys

def load_profile_recursive(profile_name, profiles_dir, loaded_profiles=None):
    if loaded_profiles is None:
        loaded_profiles = set()
        
    if profile_name in loaded_profiles:
        return {} # Prevent infinite recursion loops
        
    loaded_profiles.add(profile_name)
    
    profile_path = os.path.join(profiles_dir, f"{profile_name}.json")
    if not os.path.exists(profile_path):
        print(f"⚠️  Warning: Inherited profile '{profile_name}' not found at {profile_path}")
        return {}

    with open(profile_path, 'r') as f:
        try:
            data = json.load(f)
        except json.JSONDecodeError as e:
            print(f"⚠️  Error: Invalid JSON in profile '{profile_name}': {e}")
            return {}

    # Handle inheritance first
    merged_data = {}
    if "inherit" in data:
        inherits = data["inherit"]
        if isinstance(inherits, str):
            inherits = [inherits]
            
        for parent in inherits:
            parent_data = load_profile_recursive(parent, profiles_dir, loaded_profiles)
            
            # Merge parent data into current data
            for perm_type, rules in parent_data.items():
                if perm_type not in merged_data:
                    merged_data[perm_type] = {}
                
                if isinstance(rules, str):
                    merged_data[perm_type] = rules
                elif isinstance(rules, dict):
                    if not isinstance(merged_data[perm_type], dict):
                        merged_data[perm_type] = {}
                    # Add parent rules
                    for pattern, action in rules.items():
                        merged_data[perm_type][pattern] = action
                        
    # Now apply the current profile's own rules (they override inherited ones if they conflict in key order)
    for perm_type, rules in data.items():
        if perm_type == "inherit":
            continue
            
        if perm_type not in merged_data:
            merged_data[perm_type] = {}
            
        if isinstance(rules, str):
            merged_data[perm_type] = rules
        elif isinstance(rules, dict):
            if not isinstance(merged_data[perm_type], dict):
                merged_data[perm_type] = {}
            # Add current rules
            for pattern, action in rules.items():
                merged_data[perm_type][pattern] = action
                
    return merged_data


def main():
    if len(sys.argv) < 2:
        print("Usage: opencode-profile <profile_name...> | clear")
        print("Profiles are loaded from: ~/.config/nvim/scripts/opencode-profiles/")
        print("Example: opencode-profile git-read git-stash")
        return

    profile_names = sys.argv[1:]

    db_path = os.path.expanduser("~/.local/share/opencode/opencode.db")
    if not os.path.exists(db_path):
        print("Error: Database not found.")
        return

    conn = sqlite3.connect(db_path)
    cur = conn.cursor()

    # Get the most recently active session
    cur.execute("SELECT id FROM session ORDER BY time_updated DESC LIMIT 1")
    row = cur.fetchone()
    if not row:
        print("No sessions found.")
        return
    session_id = row[0]

    # Special case: clearing all session permissions
    if "clear" in [p.lower() for p in profile_names]:
        cur.execute("UPDATE session SET permission = NULL WHERE id = ?", (session_id,))
        conn.commit()
        conn.close()
        print(f"✅ Cleared all temporary permissions for session {session_id}")
        print("   (It will now fallback to your default opencode.json rules)")
        print("\n⚡ The new permissions will take effect on your next chat message!")
        return

    profiles_dir = os.path.expanduser("~/.config/nvim/scripts/opencode-profiles/")
    
    combined_profile_data = {}

    for profile_name in profile_names:
        profile_path = os.path.join(profiles_dir, f"{profile_name}.json")
        if not os.path.exists(profile_path):
            print(f"Error: Profile file not found at {profile_path}")
            return

        # Load and merge profile data recursively
        profile_data = load_profile_recursive(profile_name, profiles_dir)

        # Merge this profile's data into the combined data (overriding earlier ones)
        for perm_type, rules in profile_data.items():
            if perm_type not in combined_profile_data:
                combined_profile_data[perm_type] = {}
                
            if isinstance(rules, str):
                combined_profile_data[perm_type] = rules
            elif isinstance(rules, dict):
                if not isinstance(combined_profile_data[perm_type], dict):
                    combined_profile_data[perm_type] = {}
                for pattern, action in rules.items():
                    combined_profile_data[perm_type][pattern] = action

    # Mirroring Opencode's internal "fromConfig" translation logic!
    ruleset = []
    
    # ALWAYS inject a baseline allow-all rule at the top.
    # This prevents Opencode from completely overriding the global opencode.json
    # and wiping out non-bash permissions (like MCP tools, reads, external_directory, etc)
    # Because it is at the very top (index 0), it acts as a global fallback that has the 
    # lowest possible priority for the findLast() engine.
    ruleset.append({
        "permission": "*",
        "pattern": "*",
        "action": "allow"
    })
    
    for permission, value in combined_profile_data.items():
        if isinstance(value, str):
            ruleset.append({
                "permission": permission,
                "pattern": "*",
                "action": value
            })
        elif isinstance(value, dict):
            # Because Python preserves dictionary insertion order,
            # the last key in your JSON block will be appended last,
            # giving it the HIGHEST priority via Opencode's findLast()!
            for pattern, action in value.items():
                ruleset.append({
                    "permission": permission,
                    "pattern": pattern,
                    "action": action
                })

    new_json = json.dumps(ruleset)

    # Update the SQLite database for ALL recent sessions to guarantee we hit the active one
    # This prevents the "ghost session" race condition where another background process
    # grabs the latest timestamp right before we query it.
    cur.execute("UPDATE session SET permission = ? WHERE time_updated > (strftime('%s', 'now') - 86400) * 1000", (new_json,))
    conn.commit()
    conn.close()

    # Log the switch
    import datetime
    log_dir = os.path.expanduser("~/.local/state")
    if not os.path.exists(log_dir):
        os.makedirs(log_dir)
    log_file = os.path.join(log_dir, "opencode-profile.log")
    timestamp = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    joined_profiles = " + ".join(profile_names)
    with open(log_file, "a") as f:
        f.write(f"[{timestamp}] Switched to profile: {joined_profiles}\n")

    print(f"✅ Applied combined profiles '{joined_profiles}' to all recent sessions!")
    print("   Rules applied (bottom-most rules have highest priority!):")
    for rule in ruleset:
        print(f"   - {rule['action'].upper()}: {rule['permission']} -> {rule['pattern']}")
    print("\n⚡ The new permissions will take effect on your next chat message!")

if __name__ == "__main__":
    main()
